@page
@model GameBugTracker.Pages.BugReports.CreateModel
@using GameBugTracker.Models
@{
    ViewData["Title"] = "New Bug Report";
}

<div class="py-4">
    <h1 class="mb-3">New Bug Report</h1>
    <p class="text-muted">Capture a new bug for the current game project.</p>

    <form method="post" class="mt-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="BugReport.Title" class="form-label"></label>
            <input asp-for="BugReport.Title" class="form-control" />
            <span asp-validation-for="BugReport.Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="BugReport.Description" class="form-label"></label>
            <textarea asp-for="BugReport.Description" class="form-control" rows="5"></textarea>
            <span asp-validation-for="BugReport.Description" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="BugReport.Severity" class="form-label"></label>
                <select asp-for="BugReport.Severity" asp-items="Html.GetEnumSelectList<BugSeverity>()" class="form-select"></select>
            </div>

            <div class="col-md-6">
                <label asp-for="BugReport.Status" class="form-label"></label>
                <select asp-for="BugReport.Status" asp-items="Html.GetEnumSelectList<BugStatus>()" class="form-select"></select>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Bug Report</button>
            <a class="btn btn-outline-secondary" asp-page="/BugReports/Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
