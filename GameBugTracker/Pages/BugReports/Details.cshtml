@page "{id:int}"
@model GameBugTracker.Pages.BugReports.DetailsModel
@{
    ViewData["Title"] = "Bug Details";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">@Model.BugReport!.Title</h1>
            <p class="text-muted mb-0">Bug report details for the current game project.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a class="btn btn-primary" asp-page="/BugReports/Edit" asp-route-id="@Model.BugReport.Id">Edit Bug Report</a>
            }
            <a class="btn btn-outline-secondary" asp-page="/BugReports/Index">Back to List</a>
        </div>
    </div>

    <dl class="row">
        <dt class="col-sm-3">Severity</dt>
        <dd class="col-sm-9">@Model.BugReport.Severity</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.BugReport.Status</dd>

        <dt class="col-sm-3">Created</dt>
        <dd class="col-sm-9">@Model.BugReport.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.BugReport.Description</dd>
    </dl>
</div>
