@page
@model GameBugTracker.Pages.BugReports.IndexModel
@{
    ViewData["Title"] = "Bug Reports";
}

<div class="py-4">
    <h1 class="mb-3">Bug Reports</h1>
    <p class="text-muted">Current bugs for the game project.</p>

    @if (Model.BugReports.Count == 0)
    {
        <p>No bug reports yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bug in Model.BugReports)
                    {
                        <tr>
                            <td>@bug.Title</td>
                            <td>@bug.Severity</td>
                            <td>@bug.Status</td>
                            <td>@bug.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
