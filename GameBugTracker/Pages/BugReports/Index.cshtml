@page
@model GameBugTracker.Pages.BugReports.IndexModel
@{
    ViewData["Title"] = "Bug Reports";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Bug Reports</h1>
            <p class="text-muted mb-0">Current bugs for the game project.</p>
        </div>
        <a class="btn btn-primary" asp-page="/BugReports/Create">New Bug Report</a>
    </div>

    @if (Model.BugReports.Count == 0)
    {
        <p>No bug reports yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bug in Model.BugReports)
                    {
                        <tr>
                            <td>
                                <a asp-page="/BugReports/Details" asp-route-id="@bug.Id">@bug.Title</a>
                            </td>
                            <td>@bug.Severity</td>
                            <td>@bug.Status</td>
                            <td>@bug.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
