@page
@model IndexModel
@inject IOptions<SiteOwnerOptions> SiteOwnerOptionsAccessor
@{
    ViewData["Title"] = "Home";
    var owner = SiteOwnerOptionsAccessor.Value;
}

<div class="py-4">
    <h1 class="display-5 mb-3">Game Bug Tracker</h1>
    <p class="lead">
        Track bugs for your game project, keep the backlog organized, and build a clear record of what needs attention.
    </p>
    <p class="text-muted">
        Created by <strong>@owner.Name</strong> as a public portfolio demo for junior C# / .NET roles.
    </p>

    <div class="d-flex gap-2 mt-4">
        <a class="btn btn-primary" asp-page="/BugReports/Index">View Bug Reports</a>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a class="btn btn-outline-secondary" asp-page="/BugReports/Create">Create Bug Report</a>
        }
        else
        {
            <a class="btn btn-outline-secondary" asp-page="/Auth/Login">Owner Sign In</a>
        }
    </div>

    <div class="mt-4">
        <h2 class="h4">Version 1 Goal</h2>
        <p>
            Start with a simple internal tracker for one game project. Players will be able to submit bugs in a later version.
        </p>
    </div>

    <div class="mt-4">
        <h2 class="h4">What This App Will Do</h2>
        <ul>
            <li>List bug reports</li>
            <li>Create new bug reports</li>
            <li>View bug details</li>
            <li>Update bug status and severity</li>
        </ul>
    </div>

    <div class="mt-4 border rounded p-3 bg-light">
        <h2 class="h5 mb-2">Public Demo Access</h2>
        <p class="mb-0">
            Recruiters and interviewers can browse the tracker anonymously. Creating or editing bug reports is reserved for the owner account.
        </p>
    </div>
</div>
